{
    "name": "retroachievements/api",
    "description": "RetroAchievements Web API Client",
    "type": "library",
    "keywords": [
        "RetroAchievmenets",
        "retro",
        "achievements",
        "API"
    ],
    "homepage": "https://github.com/retroachievements/api-php",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.12"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "RetroAchievements\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RetroAchievements\\Providers\\RetroAchievementsProvider"
            ],
            "aliases": {
                "RetroAchievements": "RetroAchievements\\Facades\\RetroAchievements"
            }
        }
    },
    "scripts": {
        "test":  "vendor/bin/phpunit --testdox",
        "lint":  "vendor/bin/pint --test",
        "fix":   "vendor/bin/pint",
        "stan":  "vendor/bin/phpstan analyse",
        "check": ["@lint", "@stan", "@test"]
    },
    "require-dev": {
        "laravel/framework": "^13.17",
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^13.2",
        "vlucas/phpdotenv": "^5.6"
    }
}
